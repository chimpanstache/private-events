<h1> Welcome to Private Events </h1>

<% @events.each do |event| %>
  <% if event.errors.any? %>
    <div>
      <% event.errors.full_messages.each do |message| %>
        <div> <%= message %> </div>
      <% end %>
    </div>
  <% end %>
  <p>
    <%= event.title %>
  </p>
  <p>
    <%= event.date %>
  </p>
<% end %>
